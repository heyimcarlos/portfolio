---
type Active = 'home' | 'work' | 'blog' | 'about';

interface Props {
  active?: Active;
}

const { active } = Astro.props;

const items: { key: Active; label: string; href: string }[] = [
  { key: 'work', label: 'work', href: '/projects' },
  { key: 'about', label: 'about', href: '/about' },
  { key: 'blog', label: 'writing', href: '/blog' },
];
---

<nav class="qm-nav">
  <a href="/" class="qm-mark" aria-label="Carlos — home">
    <span class="qm-dot" aria-hidden="true"></span>
    carlos · open to positions
  </a>
  <span class="qm-nav-links">
    {
      items.map((item) => (
        <a
          href={item.href}
          class="qm-navlink"
          data-active={item.key === active ? 'true' : 'false'}
          aria-current={item.key === active ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </span>
</nav>
