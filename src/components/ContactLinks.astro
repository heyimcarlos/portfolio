---
export type ContactLink = {
  label: string;
  value: string;
  href: string;
};

interface Props {
  links: ContactLink[];
}

const { links } = Astro.props;
---

<div class="links">
  {
    links.map((link) => (
      <a class="link" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
        <span class="label">{link.label}</span>
        <span class="value">
          {link.value} <span aria-hidden="true">↗</span>
        </span>
      </a>
    ))
  }
</div>

<style>
  .links {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    background: var(--zine-paper);
    border: 3px solid var(--zine-ink);
    box-shadow: 5px 5px 0 var(--zine-ink);
    padding: 16px 18px;
    transition:
      transform 120ms ease,
      box-shadow 120ms ease;
  }

  .link:hover {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0 var(--zine-ink);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    opacity: 0.7;
  }

  .value {
    font-size: 15px;
    font-weight: 700;
  }
</style>
