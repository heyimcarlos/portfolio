---
interface Props {
  next?: { label?: string; href?: string };
}

const { next } = Astro.props;
---

<footer class="zine-footer">
  <span>heyimcarlos.dev</span>
  <span class="middle">printed on the internet · © carlos</span>
  {
    next?.href ? (
      <a href={next.href}>{next.label ?? 'turn page →'}</a>
    ) : (
      <span>{next?.label ?? 'turn page →'}</span>
    )
  }
</footer>

<style>
  .zine-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 32px;
    background: var(--zine-paper);
    border-top: 3px solid var(--zine-ink);
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .zine-footer {
      padding: 12px 20px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .middle {
      order: 3;
      flex-basis: 100%;
      text-align: center;
    }
  }
</style>
