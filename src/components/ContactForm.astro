---
import Button from './Button.astro';

interface Props {
  action?: string;
  method?: 'POST' | 'GET';
  enctype?: string;
}

const { action = '/api/contact', method = 'POST', enctype } = Astro.props;
---

<form class="postcard" action={action} method={method} enctype={enctype}>
  <input
    class="hp"
    type="text"
    name="website"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />
  <h3 class="title">Send a postcard</h3>
  <label class="field">
    <span>name</span>
    <input name="name" type="text" required autocomplete="name" />
  </label>
  <label class="field">
    <span>email</span>
    <input name="email" type="email" required autocomplete="email" />
  </label>
  <label class="field">
    <span>message</span>
    <textarea name="message" rows={4} required minlength={10} placeholder="dear carlos,"></textarea>
  </label>
  <Button type="submit" variant="primary" class="submit">Stamp &amp; send →</Button>
</form>

<style>
  .postcard {
    background: var(--zine-paper);
    border: 3px solid var(--zine-ink);
    box-shadow: 6px 6px 0 var(--zine-ink);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .title {
    margin: 0 0 2px;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.4px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .field span {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    opacity: 0.6;
  }

  input,
  textarea {
    background: var(--zine-bg);
    border: 2.5px solid var(--zine-ink);
    padding: 10px 12px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--zine-ink);
    outline: none;
    border-radius: 0;
  }

  textarea {
    min-height: 90px;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 400;
    opacity: 0.5;
  }

  .submit {
    width: 100%;
  }

  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
</style>
