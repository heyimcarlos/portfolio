---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import Button from '../components/Button.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SubscribeStrip from '../components/SubscribeStrip.astro';
import Tag from '../components/Tag.astro';

type Neighbor = { id: string; title: string };

type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  prev?: Neighbor;
  next?: Neighbor;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tag,
  readTime,
  featured,
  slug,
  prev,
  next,
} = Astro.props;

const postUrl = new URL(`/blog/${slug}/`, Astro.site ?? 'https://heyimcarlos.dev').toString();
const shareText = encodeURIComponent(title);
const shareUrl = encodeURIComponent(postUrl);
const twitterHref = `https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`;
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
---

<Layout title={`${title} — Carlos`} description={description} active="blog">
  <section class="header">
    <a class="back" href="/blog/">← all posts</a>
    <div class="eyebrow">
      {featured && <span class="pill">★ FEATURED</span>}
      <span class="dots">{tag} · {readTime ?? ''}</span>
    </div>
    <h1 class="title">{title}</h1>
    <p class="date">
      <FormattedDate date={pubDate} />
      {
        updatedDate && (
          <>
            {' · updated '}
            <FormattedDate date={updatedDate} />
          </>
        )
      }
    </p>
  </section>

  {
    heroImage && (
      <section class="hero">
        <div class="hero-frame">
          <Image src={heroImage} alt={title} class="hero-img" />
        </div>
      </section>
    )
  }

  <section class="body">
    <article class="prose">
      <slot />
    </article>
  </section>

  <section class="meta">
    <div class="meta-col tags">
      <span class="k">Filed under</span>
      <a href={`/blog/filter/${tag}/`} class="tag-link">
        <Tag variant="accent">{tag}</Tag>
      </a>
    </div>
    <div class="meta-col share">
      <span class="k">Share</span>
      <div class="share-row">
        <Button href={twitterHref} size="sm" variant="ghost">X ↗</Button>
        <Button href={linkedinHref} size="sm" variant="ghost">LinkedIn ↗</Button>
        <button type="button" class="rb-btn rb-btn--sm rb-btn--ghost" data-copy={postUrl}>
          Copy link
        </button>
      </div>
    </div>
    <div class="meta-col byline">
      <span class="k">Written by</span>
      <span class="v">Carlos <span class="sparkle">✦</span></span>
    </div>
  </section>

  {
    (prev || next) && (
      <section class="navp">
        <a
          class="navp-cell"
          href={prev ? `/blog/${prev.id}/` : '#'}
          style={!prev ? 'visibility:hidden' : ''}
        >
          <span class="navp-k">← Previous</span>
          <span class="navp-v">{prev?.title ?? ''}</span>
        </a>
        <a
          class="navp-cell right"
          href={next ? `/blog/${next.id}/` : '#'}
          style={!next ? 'visibility:hidden' : ''}
        >
          <span class="navp-k">Next →</span>
          <span class="navp-v">{next?.title ?? ''}</span>
        </a>
      </section>
    )
  }

  <SubscribeStrip />
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('button[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.copy;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = 'Copied ✓';
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      } catch {
        /* noop */
      }
    });
  });
</script>

<style>
  section {
    border-bottom: 3px solid var(--zine-ink);
  }

  .header {
    padding: 64px 32px 32px;
    background: var(--zine-bg);
    text-align: center;
  }

  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.7;
    margin-bottom: 20px;
  }

  .back:hover {
    text-decoration: underline;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .pill {
    background: var(--zine-accent);
    border: 2px solid var(--zine-ink);
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .dots {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.6;
  }

  .title {
    margin: 0 auto;
    max-width: 780px;
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 0.98;
    font-size: clamp(36px, 5.5vw, 56px);
  }

  .date {
    margin: 12px 0 0;
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.7;
  }

  .hero {
    padding: 0 32px;
    background: var(--zine-bg);
    border-bottom: 0;
  }

  .hero-frame {
    max-width: 880px;
    margin: 40px auto 40px;
    aspect-ratio: 16 / 9;
    border: 3px solid var(--zine-ink);
    box-shadow: 8px 8px 0 var(--zine-ink);
    overflow: hidden;
    background: var(--zine-paper);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .body {
    padding: 48px 32px;
    background: var(--zine-bg);
  }

  .prose {
    max-width: 680px;
    margin: 0 auto;
  }

  .prose :global(p) {
    font-size: 17px;
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .prose :global(h2) {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.8px;
    margin: 40px 0 12px;
  }

  .prose :global(h3) {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.4px;
    margin: 28px 0 8px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-size: 17px;
    line-height: 1.7;
    padding-left: 24px;
    margin: 0 0 18px;
  }

  .prose :global(em) {
    font-style: italic;
    font-weight: 500;
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--zine-bg);
    border: 2px solid var(--zine-ink);
    padding: 1px 5px;
  }

  .prose :global(pre) {
    background: var(--zine-paper);
    border: 3px solid var(--zine-ink);
    box-shadow: 6px 6px 0 var(--zine-ink);
    padding: 16px;
    font-size: 13px;
    line-height: 1.6;
    overflow-x: auto;
    margin: 0 0 22px;
  }

  .prose :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: 6px solid var(--zine-accent);
    padding: 4px 0 4px 18px;
    font-style: italic;
    opacity: 0.9;
    margin: 24px 0;
  }

  .prose :global(hr) {
    height: 0;
    border: 0;
    border-top: 2px dashed var(--zine-ink);
    opacity: 0.5;
    margin: 32px 0;
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    border: 3px solid var(--zine-ink);
    box-shadow: 6px 6px 0 var(--zine-ink);
    margin: 12px 0 22px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    border: 3px solid var(--zine-ink);
    margin: 0 0 22px;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 2px solid var(--zine-ink);
    padding: 10px 14px;
    text-align: left;
  }

  .prose :global(thead th) {
    background: var(--zine-accent);
  }

  .prose :global(tbody tr:nth-child(even)) {
    background: var(--zine-paper);
  }

  .meta {
    padding: 32px;
    background: var(--zine-paper);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .meta-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .meta-col .k {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.7;
  }

  .share-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .share {
    align-items: center;
    text-align: center;
  }

  .byline {
    align-items: flex-end;
    text-align: right;
  }

  .byline .v {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 14px;
  }

  .byline .sparkle {
    color: var(--zine-accent);
  }

  .tag-link {
    display: inline-flex;
  }

  @media (max-width: 768px) {
    .meta {
      grid-template-columns: 1fr;
    }
    .share,
    .byline {
      align-items: flex-start;
      text-align: left;
    }
  }

  .navp {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--zine-paper);
  }

  .navp-cell {
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: inherit;
    text-decoration: none;
    border-right: 3px solid var(--zine-ink);
  }

  .navp-cell.right {
    border-right: 0;
    text-align: right;
    align-items: flex-end;
  }

  .navp-k {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    opacity: 0.6;
  }

  .navp-v {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.3px;
  }

  .navp-cell:hover .navp-v {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .navp {
      grid-template-columns: 1fr;
    }
    .navp-cell {
      border-right: 0;
      border-bottom: 3px solid var(--zine-ink);
    }
    .navp-cell:last-child {
      border-bottom: 0;
    }
    .navp-cell.right {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
