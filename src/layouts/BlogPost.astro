---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

type Neighbor = { id: string; title: string };

type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  prev?: Neighbor;
  next?: Neighbor;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  readTime,
  excerpt,
  prev,
  next,
} = Astro.props;

const formatDate = (d: Date) =>
  `${d.getFullYear()} · ${String(d.getMonth() + 1).padStart(2, '0')}`;

const date = formatDate(pubDate);
const subtitle = excerpt ?? description;
---

<Layout title={`${title} — Carlos`} description={description} active="blog" image={heroImage}>
  <a href="/blog" class="qm-back">← back to writing</a>

  <header class="qm-page-head">
    <span class="qm-page-tag">{date} · {readTime ?? ''}</span>
    <h1 class="qm-h1">{title}.</h1>
    {subtitle && <p class="qm-lead">{subtitle}</p>}
    {
      updatedDate && (
        <p class="qm-updated">updated {formatDate(updatedDate)}</p>
      )
    }
  </header>

  <article class="qm-prose">
    <slot />
  </article>

  {
    (prev || next) && (
      <nav class="qm-navp">
        {prev ? (
          <a class="qm-navp-cell" href={`/blog/${prev.id}`}>
            <span class="qm-navp-k">← Previous</span>
            <span class="qm-navp-v">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="qm-navp-cell right" href={`/blog/${next.id}`}>
            <span class="qm-navp-k">Next →</span>
            <span class="qm-navp-v">{next.title}</span>
          </a>
        ) : <span />}
      </nav>
    )
  }
</Layout>

<style>
  .qm-updated {
    margin: 18px 0 0;
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .qm-prose {
    max-width: 64ch;
    font-size: 17px;
    line-height: 1.75;
    color: var(--fg-2);
  }

  .qm-prose :global(p) {
    margin: 0 0 22px;
  }

  .qm-prose :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }

  .qm-prose :global(em) {
    color: var(--fg);
    font-style: italic;
    font-weight: 400;
  }

  .qm-prose :global(a) {
    color: var(--fg);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .qm-prose :global(a:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .qm-prose :global(h2) {
    font-size: 24px;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 48px 0 16px;
  }

  .qm-prose :global(h3) {
    font-size: 18px;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 32px 0 12px;
  }

  .qm-prose :global(ul),
  .qm-prose :global(ol) {
    margin: 0 0 22px;
    padding-left: 0;
    list-style: none;
  }

  .qm-prose :global(li) {
    padding: 8px 0;
    border-bottom: 1px solid var(--rule);
    display: flex;
    gap: 14px;
    align-items: baseline;
  }

  .qm-prose :global(li:last-child) {
    border-bottom: none;
  }

  .qm-prose :global(li::before) {
    content: '→';
    color: var(--accent);
    flex-shrink: 0;
  }

  .qm-prose :global(blockquote) {
    margin: 32px 0;
    padding: 0 0 0 24px;
    border-left: 2px solid var(--accent);
    color: var(--fg);
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    max-width: 32ch;
  }

  .qm-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--fg);
  }

  .qm-prose :global(pre) {
    background: rgba(244, 243, 238, 0.04);
    border: 1px solid var(--rule);
    padding: 16px 18px;
    font-size: 13px;
    line-height: 1.6;
    overflow-x: auto;
    margin: 0 0 22px;
  }

  .qm-prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .qm-prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 40px 0;
  }

  .qm-prose :global(img) {
    display: block;
    width: 100%;
    border: 1px solid var(--rule);
    margin: 16px 0 22px;
  }

  .qm-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 22px;
    font-size: 14px;
  }

  .qm-prose :global(th),
  .qm-prose :global(td) {
    border-bottom: 1px solid var(--rule);
    padding: 10px 12px;
    text-align: left;
  }

  .qm-prose :global(thead th) {
    color: var(--fg-3);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .qm-navp {
    margin-top: 96px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .qm-navp-cell {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: inherit;
    text-decoration: none;
  }

  .qm-navp-cell.right {
    align-items: flex-end;
    text-align: right;
  }

  .qm-navp-k {
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .qm-navp-v {
    font-size: 16px;
    color: var(--fg);
    font-weight: 500;
    transition: color 0.2s;
  }

  .qm-navp-cell:hover .qm-navp-v {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .qm-navp {
      grid-template-columns: 1fr;
    }
    .qm-navp-cell.right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
