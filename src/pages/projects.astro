---
import { Image } from '@astrojs/image/components'
import Heading from '../components/Heading'
import MotionSection from '../components/MotionSection'
import ProjectGridItem from '../components/ProjectGridItem.astro'
import Page from '../layouts/page.astro'
import type { Project } from '../types/project'
const projects = (await Astro.glob<Project>('./projects/**/*.md')).sort(
  (a, b) =>
    new Date(b.frontmatter.createdAt).valueOf() >
    new Date(a.frontmatter.createdAt).valueOf()
      ? 1
      : -1
)

const games = await Astro.glob('./games/**/*.astro')
---

<Page
  title="Portfolio page"
  description="Carlos's portfolio page"
  heading="The following list includes personal, freelance and work projects."
  lang="en"
>
  <!-- Games -->
  {
    games.map(game => {
      return (
        <MotionSection client:load delay={0.1}>
          <div class="w-full my-8">
            <a href={game.url} class="inline-block">
              <Heading as="h1" variant="section-title">
                {'Snake'}
              </Heading>
            </a>
            <div class="relative shadow-xl overflow-hidden rounded-2xl">
              <div class="hover:scale-125 transition-all duration-500">
                <Image
                  src={`../../public${game.url}.png`}
                  alt={'Snake'}
                  width={720}
                  position="top"
                  aspectRatio={1.7}
                  decoding="async"
                  loading="lazy"
                  class="rounded-xl min-h-full min-w-full max-h-full max-w-full border border-slate-300 dark:border-zinc-700"
                />
                opacity overlay
                <a
                  href={game.url}
                  class="absolute cursor-default top-0 left-0 w-full h-full flex justify-center items-center flex-col rounded-md hover:bg-opacity-30 dark:hover:bg-opacity-40 hover:bg-orange-50 dark:hover:bg-custom-zinc transition-all duration-500 [&>button]:hover:opacity-100"
                >
                  <button class="opacity-0 font-mplus rounded-md border border-zinc-400 dark:border-zinc-700 px-2 py-2 text-sm font-medium shadow-sm hover:bg-zinc-400 dark:hover:bg-zinc-700 focus:outline-none focus:ring-2 focus:ring-custom-blue focus:ring-offset-2 focus:ring-offset-gray-100 transition-all scale-100">
                    Inspect
                  </button>
                </a>
              </div>
            </div>
          </div>
        </MotionSection>
      )
    })
  }

  {
    projects.map((project, idx) => (
      <MotionSection client:load delay={!idx ? 0.2 : idx / 2.5}>
        <ProjectGridItem project={project} />
      </MotionSection>
    ))
  }
</Page>
