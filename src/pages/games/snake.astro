            // if (e.key.startsWith('Arrow')) {
            //   e.preventDefault()
            // }
            // })
            // const canvas = document.getElementById('snake-canvas')
            // function resizeCanvas() {
            //   if (!canvas) return
            //   // Apply the width in percentage and control height accordingly
            //   canvas.style.width = '100%'
            //   console.dir(canvas)
            //   // canvas.width = canvas.offsetWidth
            //   // canvas.height = canvas.offsetHeight // Adjust this line if you maintain a specific aspect ratio
            // }

            // window.addEventListener('resize', resizeCanvas)

            init()
              .then(() => {
                // if (!canvas) return
                // console.log('RUNNING')
                // canvas.style.width = '100%'
                // resizeCanvas()
              })
              .catch(console.error)
          </script>
        </MotionSection>
      </article>
    </main>
  </Body>
  <!-- </Page> -->
</html>
