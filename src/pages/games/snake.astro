      //   // canvas.width = canvas.offsetWidth
      //   // canvas.height = canvas.offsetHeight // Adjust this line if you maintain a specific aspect ratio
      // }

      // window.addEventListener('resize', resizeCanvas)

      init()
        .then(() => {
          // if (!canvas) return
          // console.log('RUNNING')
          // canvas.style.width = '100%'
          // resizeCanvas()
        })
        .catch(console.error)
    </script>
  </MotionSection>
</Page>
