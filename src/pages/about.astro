---
import Layout from '../layouts/Layout.astro';
import Timeline, { type TimelineEvent } from '../components/Timeline.astro';
import Tag from '../components/Tag.astro';

const TIMELINE_EVENTS: TimelineEvent[] = [
  {
    year: '1995',
    place: 'Santo Domingo, DO',
    role: 'Born',
    type: 'life',
    desc: 'Sports, gaming, and an early obsession with competitive anything.',
  },
  {
    year: '2014 — 2019',
    place: 'Web',
    role: 'Esports Live Streamer',
    org: 'Twitch',
    type: 'edu',
    desc: 'Competitive gaming livestream with a community of 200+ viewers.',
  },
  {
    year: '2019',
    place: 'Santo Domingo, DO',
    role: 'B.B.A. Business Administration',
    org: 'Pontifical Catholic University (PUCMM)',
    type: 'edu',
    desc: 'Graduated business school.',
  },
  {
    year: '2019',
    place: 'Santo Domingo, DO',
    role: 'Analyst',
    org: 'ScotiaBank',
    type: 'work',
    desc: 'Realized finance was not it. Started eyeing a different kind of problem-solving.',
  },
  {
    year: '2020',
    place: 'New York, NY',
    role: 'Software Engineering Immersive',
    org: 'Fullstack Academy',
    type: 'edu',
    desc: 'Completed the bootcamp — React, Node, Express, PostgreSQL. First time code felt addictive.',
  },
  {
    year: '2020 — 2022',
    place: 'Remote',
    role: 'Full-Stack Developer',
    org: '305 Global Marketing',
    type: 'work',
    desc: 'Shipped a multi-tenant e-commerce platform and an ops dashboard on Next.js + AWS + PostgreSQL + Mongo. ~250k annual revenue.',
  },
  {
    year: '2022 — 2023',
    place: 'Remote',
    role: 'SDE II',
    org: 'Exactera',
    type: 'work',
    desc: 'Implemented ML-powered vector search at scale.',
  },
  {
    year: '2023 — 2026',
    place: 'Toronto, CA',
    role: 'Software Engineering Technology - AI (AdvDip)',
    org: 'Centennial College',
    type: 'edu',
    desc: 'Full-time student, two part-time jobs. GPA 4.4/4.5. Member of the Engineerging Student Association. Math tutor. Scholarship recipient.',
  },
  {
    year: '2024',
    place: 'Toronto, CA',
    role: 'Lead Software Developer & Coordinator',
    org: 'Centennial OER Lab',
    type: 'work',
    desc: 'Led engineering on open educational tools for 12k+ students. Type-safe, small team, high-leverage.',
  },
  {
    year: '2025 — 2026',
    place: 'Toronto, CA',
    role: 'Fullstack Software Engineer',
    org: 'Xello',
    type: 'work',
    desc: 'Major contributor to "The Real Game" — a career exploration tool used by millions of students.',
  },
  {
    year: '2026',
    place: 'Toronto, CA',
    role: 'Machine Learning Engineer',
    org: 'TI Automotive',
    type: 'work',
    desc: 'Built an Inverse model-based Reinforcement Learning model to predict polymer blends from OEM specs, now a tool used by Lab Techs.',
  },
];

const STACK: { category: string; items: string[] }[] = [
  { category: 'Languages', items: ['TypeScript', 'JS', 'Python', 'Go', 'Rust'] },
  { category: 'Frontend', items: ['React', 'Next', 'Astro', 'Tailwind', 'Angular'] },
  { category: 'Backend', items: ['Node', 'Postgres', 'MySQL', 'Redis', 'FastAPI', 'tokio'] },
  { category: 'Infra', items: ['Vercel', 'AWS', 'Docker', 'GH Actions', 'circleci', 'terraform', 'huggingface', 'n8n'] },
  { category: 'ML', items: ['pytorch', 'harness engineering', 'context engineering', 'LLM fine-tuning', 'LoRA'] },
];
---

<Layout
  title="About — Carlos"
  description="Dominican software engineer. Came for the gaming, stayed for the compiler."
  active="about"
>
  <section class="origins">
    <span class="eyebrow">CHAPTER 01 · ORIGINS</span>
    <h1 class="h1">
      I came for the gaming, <em>stayed</em> for the compiler<span class="dot">.</span>
    </h1>
    <div class="prose">
      <p>
        I spent my teens trying to go pro at SOCOM, Counter-Strike, and later Fortnite. I made it.
        Then I tried finance, and it wasn't it — I wanted work where the output scaled with the
        effort. At a family wedding, a cousin said, "you should learn to code."
      </p>
      <p>
        One bootcamp, a software engineering degree, a move to Toronto, and a few jobs later, I'm
        focused on <mark>AI engineering and machine learning</mark> — retrieval systems,
        Reinforcement Learning, and the unglamorous plumbing that makes models useful in
        production.
      </p>
      <p>
      Outside the screen: BJJ (blue belt, forever), snowboarding, surfing, building silly things. This site is one of them.
      </p>
    </div>
  </section>

  <section class="timeline-section">
    <span class="eyebrow">CHAPTER 02 · THE TIMELINE</span>
    <h2 class="h2">
      The long <em>way</em> here<span class="dot">.</span>
    </h2>
    <p class="subtitle">~31 years · 4 cities · 1 reasonably consistent career</p>
    <Timeline events={TIMELINE_EVENTS} />
  </section>

  <section class="stack-section">
    <span class="eyebrow">CHAPTER 03 · THE STACK</span>
    <h2 class="h2 stack-title">
      Tools of the <em>trade</em><span class="dot">.</span>
    </h2>
    <div class="stack-grid">
      {
        STACK.map((group) => (
          <div class="stack-card">
            <div class="stack-label">{group.category}</div>
            <div class="stack-tags">
              {group.items.map((item) => (
                <Tag variant="bg">{item}</Tag>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="meta-strip">
    <div class="meta-grid">
      <div class="meta-cell">
        <div class="meta-label">loc.</div>
        <div class="meta-value">Toronto, CA</div>
      </div>
      <div class="meta-cell">
        <div class="meta-label">orig.</div>
        <div class="meta-value">Santo Domingo, DO</div>
      </div>
      <div class="meta-cell">
        <div class="meta-label">tz</div>
        <div class="meta-value">EST · UTC-5</div>
      </div>
      <div class="meta-cell">
        <div class="meta-label">status</div>
        <div class="meta-value status-value">
          <span class="rb-dot-live"></span> open to roles
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  section {
    border-bottom: 3px solid var(--zine-ink);
  }

  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.6;
    margin-bottom: 8px;
  }

  em {
    font-style: italic;
    font-weight: 500;
  }

  .dot {
    color: var(--zine-accent);
  }

  .origins {
    padding: 64px 32px 48px;
    text-align: center;
  }

  .h1 {
    max-width: 820px;
    margin: 0 auto;
    font-weight: 700;
    letter-spacing: -2.4px;
    line-height: 0.95;
    font-size: clamp(38px, 6vw, 68px);
  }

  .prose {
    max-width: 720px;
    margin: 28px auto 0;
    font-size: 16px;
    line-height: 1.7;
    text-align: left;
  }

  .prose p {
    margin: 0 0 16px;
  }

  .prose mark {
    background: var(--zine-accent);
    color: inherit;
    padding: 0 3px;
  }

  .timeline-section {
    padding: 56px 32px 48px;
    text-align: center;
  }

  .timeline-section .eyebrow {
    margin-bottom: 6px;
  }

  .h2 {
    margin: 0;
    font-weight: 700;
    letter-spacing: -1.6px;
    line-height: 1;
    font-size: clamp(28px, 5vw, 44px);
    margin-bottom: 8px;
  }

  .subtitle {
    margin: 0 0 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.6;
  }

  .stack-section {
    padding: 48px 32px;
    text-align: center;
  }

  .stack-title {
    letter-spacing: -1.5px;
    font-size: clamp(28px, 4.5vw, 40px);
    margin-bottom: 28px;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    max-width: 880px;
    margin: 0 auto;
    text-align: left;
  }

  .stack-card {
    background: var(--zine-paper);
    border: 2.5px solid var(--zine-ink);
    box-shadow: 4px 4px 0 var(--zine-ink);
    padding: 14px 16px;
  }

  .stack-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .meta-strip {
    padding: 36px 32px;
    text-align: center;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .meta-cell {
    border: 2px solid var(--zine-ink);
    padding: 10px 12px;
    background: var(--zine-paper);
    text-align: left;
  }

  .meta-label {
    opacity: 0.6;
    margin-bottom: 4px;
  }

  .meta-value {
    font-weight: 700;
  }

  .status-value {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  @media (max-width: 1024px) {
    .stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .meta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
