---
import Layout from '../layouts/Layout.astro';

interface WorkRow {
  range: string;
  role: string;
  co: string;
  loc: string;
  note: string;
}

interface EduRow {
  year: string;
  what: string;
  where: string;
  loc: string;
}

const WORK: WorkRow[] = [
  {
    range: '2026 — now',
    role: 'Machine Learning Engineer',
    co: 'TI Automotive',
    loc: 'Toronto',
    note: 'Inverse-RL model predicting polymer blends from OEM specs. In production with lab techs.',
  },
  {
    range: '2025 — 26',
    role: 'Fullstack Software Engineer',
    co: 'Xello',
    loc: 'Toronto',
    note: 'Major contributor to "The Real Game" — a career-exploration tool used by millions of students.',
  },
  {
    range: '2024',
    role: 'Lead Software Developer',
    co: 'Centennial OER Lab',
    loc: 'Toronto',
    note: 'Led engineering on open educational tools for 12k+ students. Type-safe, small team, high leverage.',
  },
  {
    range: '2022 — 23',
    role: 'SDE II',
    co: 'Exactera',
    loc: 'Remote',
    note: 'Implemented ML-powered vector search at scale.',
  },
  {
    range: '2020 — 22',
    role: 'Full-Stack Developer',
    co: '305 Global Marketing',
    loc: 'Remote',
    note: 'Multi-tenant e-commerce platform + ops dashboard on Next.js + AWS + Postgres + Mongo.',
  },
];

const EDUCATION: EduRow[] = [
  {
    year: '2023 — 26',
    what: 'AdvDip · Software Engineering Tech (AI)',
    where: 'Centennial College',
    loc: 'Toronto',
  },
  {
    year: '2020',
    what: 'Software Engineering Immersive',
    where: 'Fullstack Academy',
    loc: 'New York',
  },
  {
    year: '2019',
    what: 'B.B.A. Business Administration',
    where: 'PUCMM',
    loc: 'Santo Domingo',
  },
];

const STACK: { group: string; items: string[] }[] = [
  { group: 'Languages', items: ['TypeScript', 'JavaScript', 'Python', 'Go', 'Rust'] },
  { group: 'Frontend', items: ['React', 'Next.js', 'Astro', 'Tailwind', 'Angular'] },
  { group: 'Backend', items: ['Node', 'Postgres', 'MySQL', 'Redis', 'FastAPI', 'tokio'] },
  { group: 'Infra', items: ['Vercel', 'AWS', 'Docker', 'GH Actions', 'Terraform'] },
  { group: 'ML', items: ['PyTorch', 'Hugging Face', 'LoRA', 'fine-tuning', 'RL'] },
];
---

<Layout
  title="About — Carlos"
  description="Dominican engineer based in Toronto. Currently building inverse-RL models at TI Automotive."
  active="about"
>
  <header class="qm-page-head">
    <span class="qm-page-tag">about · forever a beginner</span>
    <h1 class="qm-h1">A short <em>biography.</em></h1>
  </header>

  <div class="qm-about">
    <p>
      Dominican engineer based in <b>Toronto</b>. Spent my teens going pro at Counter-Strike
      and Fortnite, tried finance briefly, then learned to code at a kitchen table.
    </p>
    <p>
      Now focused on <b>AI engineering and machine learning</b> — retrieval systems,
      reinforcement learning, and the unglamorous plumbing that makes models useful in
      production. Outside the screen: BJJ blue belt, snowboarding, surfing, building silly
      things.
    </p>
  </div>

  <h2 class="qm-block-h2">Experience</h2>
  <div>
    {
      WORK.map((w) => (
        <div class="qm-work-row">
          <span class="qm-work-year">{w.range}</span>
          <div>
            <p class="qm-work-role">
              {w.role}, <span class="qm-work-co">{w.co}</span>
            </p>
            <p class="qm-work-note">{w.note}</p>
          </div>
          <span class="qm-work-loc">{w.loc}</span>
        </div>
      ))
    }
  </div>

  <h2 class="qm-block-h2">Education</h2>
  <div>
    {
      EDUCATION.map((e) => (
        <div class="qm-edu-row">
          <span class="qm-work-year">{e.year}</span>
          <div>
            <b>{e.what}</b>
            <em>{e.where}</em>
          </div>
          <span class="qm-work-loc">{e.loc}</span>
        </div>
      ))
    }
  </div>

  <h2 class="qm-block-h2">Stack</h2>
  <dl class="qm-stack">
    {
      STACK.map((s) => (
        <div>
          <dt>{s.group}</dt>
          <dd>{s.items.join(', ')}</dd>
        </div>
      ))
    }
  </dl>
</Layout>

<style>
  .qm-about {
    max-width: 64ch;
  }

  .qm-about p {
    color: var(--fg-2);
    font-size: 17px;
    line-height: 1.65;
    margin: 0 0 18px;
  }

  .qm-about p b {
    color: var(--fg);
    font-weight: 500;
  }

  .qm-work-row,
  .qm-edu-row {
    display: grid;
    grid-template-columns: 110px 1fr 140px;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
  }

  .qm-edu-row {
    padding: 18px 0;
  }

  .qm-work-row:last-child,
  .qm-edu-row:last-child {
    border-bottom: none;
  }

  .qm-work-year,
  .qm-work-loc {
    font-size: 13px;
    color: var(--fg-3);
    font-variant-numeric: tabular-nums;
  }

  .qm-work-loc {
    text-align: right;
  }

  .qm-work-role {
    font-size: 16px;
    color: var(--fg);
    margin: 0;
    font-weight: 500;
  }

  .qm-work-co {
    color: var(--fg-2);
    font-weight: 400;
  }

  .qm-work-note {
    font-size: 14px;
    color: var(--fg-2);
    margin: 8px 0 0;
    max-width: 64ch;
    line-height: 1.5;
  }

  .qm-edu-row b {
    color: var(--fg);
    font-weight: 500;
    font-size: 15px;
    display: block;
  }

  .qm-edu-row em {
    font-style: normal;
    color: var(--fg-2);
    font-size: 13px;
    display: block;
    margin-top: 2px;
  }

  .qm-stack {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 64px;
    margin: 0;
  }

  .qm-stack dt {
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .qm-stack dd {
    margin: 0;
    font-size: 15px;
    color: var(--fg);
  }

  @media (max-width: 720px) {
    .qm-work-row,
    .qm-edu-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 18px 0;
    }
    .qm-work-loc {
      text-align: left;
    }
    .qm-stack {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
