---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { computeReadTime } from '../lib/readTime';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.year !== b.data.year) return a.data.year < b.data.year ? 1 : -1;
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});

const blogEntries = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

const recentPosts = blogEntries
  .map((p) => ({ ...p, readTime: computeReadTime(p.body, p.data.readTime) }))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const formatDate = (d: Date) =>
  `${d.getFullYear()} · ${String(d.getMonth() + 1).padStart(2, '0')}`;
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} active="home">
  <header class="qm-page-head home-head">
    <h1 class="qm-h1 home-h1">Carlos Cruz <em>— software engineer.</em></h1>
    <div class="qm-lead home-lead">
      <p>
        I build software, mostly around <b>AI and machine learning</b>. Right now I'm shipping
        an inverse-reinforcement-learning model that predicts polymer blends at <b>TI Automotive</b>
        — it lives in production with lab technicians.
      </p>
      <p>
        Before that, I worked on a career-exploration tool for millions of students at Xello,
        led engineering at Centennial's OER Lab, and built ML-powered vector search at Exactera.
        I'm Dominican, based in Toronto, and open to roles.
      </p>
    </div>
    <div class="qm-meta">
      <span><b>Toronto, CA</b></span>
      <span>EST · UTC−5</span>
      <span>orig. Santo Domingo, DO</span>
      <span>
        <a href="/about" class="meta-link">more about me →</a>
      </span>
    </div>
  </header>

  {
    recentPosts.length > 0 && (
      <>
        <div class="qm-list-head">
          <h2>Recent writing</h2>
          <a href="/blog" class="qm-more">all essays →</a>
        </div>
        <div>
          {recentPosts.map((w) => (
            <a href={`/blog/${w.id}`} class="qm-post">
              <span class="qm-post-date">{formatDate(w.data.pubDate)}</span>
              <div>
                <h3 class="qm-post-title">{w.data.title}</h3>
                <p class="qm-post-summary">{w.data.excerpt ?? w.data.description}</p>
              </div>
              <span class="qm-post-read">{w.readTime}</span>
            </a>
          ))}
        </div>
      </>
    )
  }

  <h2 class="qm-block-h2">Selected work</h2>
  <div>
    {
      projects.map((p, i) => (
        <a href={`/projects/${p.id}`} class="qm-proj">
          <span class="qm-proj-num">№ {String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="qm-proj-title">{p.data.title}</h3>
            <p class="qm-proj-brief">{p.data.description}</p>
            <div class="qm-proj-stack">{p.data.stack.join(' · ')}</div>
          </div>
          <div class="qm-proj-meta">
            <span><b>{p.data.year}</b></span>
            <span>{p.data.role ?? p.data.category}</span>
            <span>{p.data.status}</span>
          </div>
        </a>
      ))
    }
  </div>

  <h2 class="qm-block-h2">Get in touch</h2>
  <div class="qm-contact">
    <h3>Let's build <em>something useful.</em></h3>
    <div class="qm-links">
      <a href="mailto:carlos.cruzta@gmail.com"><span>email</span>carlos.cruzta@gmail.com</a>
      <a href="https://github.com/heyimcarlos"><span>github</span>github.com/heyimcarlos</a>
      <a href="https://www.linkedin.com/in/carlos-dev"><span>linkedin</span>/in/carlos-dev</a>
      <a href="/resume.pdf"><span>résumé</span>resume.pdf</a>
    </div>
  </div>
</Layout>

<style>
  .home-head {
    margin-bottom: 96px;
    padding-top: 24px;
  }

  .home-h1 {
    font-size: clamp(34px, 3.6vw, 48px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0 0 36px;
    max-width: 22ch;
  }

  .home-lead {
    max-width: 60ch;
    font-size: 19px;
    line-height: 1.65;
  }

  .home-lead p {
    margin: 0 0 16px;
  }

  .home-lead p:last-child {
    margin: 0;
  }

  .home-lead b {
    color: var(--fg);
    font-weight: 500;
  }

  .qm-meta {
    display: flex;
    gap: 32px;
    margin-top: 36px;
    font-size: 13px;
    color: var(--fg-3);
    flex-wrap: wrap;
  }

  .qm-meta b {
    color: var(--fg);
    font-weight: 500;
  }

  .meta-link {
    color: var(--fg-2);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .meta-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .qm-post {
    display: grid;
    grid-template-columns: 110px 1fr 80px;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.25s;
  }

  .qm-post:hover {
    padding-left: 12px;
  }

  .qm-post:hover .qm-post-title {
    color: var(--accent);
  }

  .qm-post-date {
    font-size: 13px;
    color: var(--fg-3);
    font-variant-numeric: tabular-nums;
  }

  .qm-post-title {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--fg);
    margin: 0 0 8px;
    transition: color 0.2s;
  }

  .qm-post-summary {
    font-size: 14px;
    color: var(--fg-2);
    margin: 0;
    max-width: 60ch;
    line-height: 1.55;
  }

  .qm-post-read {
    font-size: 13px;
    color: var(--fg-3);
    text-align: right;
  }

  .qm-proj {
    display: grid;
    grid-template-columns: 60px 1fr 220px;
    gap: 32px;
    align-items: baseline;
    padding: 36px 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.25s;
  }

  .qm-proj:hover {
    padding-left: 12px;
  }

  .qm-proj:hover .qm-proj-title {
    color: var(--accent);
  }

  .qm-proj-num {
    font-size: 13px;
    color: var(--fg-3);
    font-variant-numeric: tabular-nums;
  }

  .qm-proj-title {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 10px;
    transition: color 0.2s;
    color: var(--fg);
  }

  .qm-proj-brief {
    font-size: 15px;
    color: var(--fg-2);
    margin: 0 0 14px;
    max-width: 56ch;
    line-height: 1.55;
  }

  .qm-proj-stack {
    font-size: 12px;
    color: var(--fg-3);
  }

  .qm-proj-meta {
    font-size: 13px;
    color: var(--fg-3);
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
    text-align: right;
  }

  .qm-proj-meta b {
    color: var(--fg-2);
    font-weight: 500;
  }

  .qm-contact {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: end;
    margin-top: 48px;
  }

  .qm-contact h3 {
    font-size: clamp(40px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
    max-width: 14ch;
  }

  .qm-contact h3 em {
    color: var(--fg-2);
    font-style: normal;
    font-weight: 400;
  }

  .qm-links {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-end;
  }

  .qm-links a {
    font-size: 15px;
    color: var(--fg-2);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: color 0.2s;
  }

  .qm-links a:hover {
    color: var(--accent);
  }

  .qm-links a span {
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    min-width: 60px;
  }

  @media (max-width: 720px) {
    .qm-post {
      grid-template-columns: 90px 1fr;
    }
    .qm-post-read {
      grid-column: 2;
      text-align: left;
      color: var(--fg-3);
    }
    .qm-proj {
      grid-template-columns: 40px 1fr;
    }
    .qm-proj-meta {
      grid-column: 2;
      align-items: flex-start;
      text-align: left;
      flex-direction: row;
      gap: 14px;
      flex-wrap: wrap;
    }
    .qm-contact {
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: flex-start;
    }
    .qm-links {
      align-items: flex-start;
    }
  }
</style>
