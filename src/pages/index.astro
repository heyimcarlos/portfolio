---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import GitHubContributionGraph from '../components/GitHubContributionGraph.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { computeReadTime } from '../lib/readTime';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.year !== b.data.year) return a.data.year < b.data.year ? 1 : -1;
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});

const blogEntries = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

const recentPosts = blogEntries
  .map((p) => ({ ...p, readTime: computeReadTime(p.body, p.data.readTime) }))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const formatDate = (d: Date) =>
  `${d.getFullYear()} · ${String(d.getMonth() + 1).padStart(2, '0')}`;
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} active="home">
  <header class="qm-page-head home-head">
    <h1 class="qm-h1 home-h1">Carlos de la Cruz.</h1>
    <p class="qm-lead home-lead">
      I build product software for AI workflows. My lanes are backend systems, applied AI, and full-stack AI product. Recent work includes a polymer-blend ML/RL system with
      <b>TI Automotive</b>, a career-exploration product used by millions of students at <b>Xello</b>, open education tools at Centennial's OER Lab, and vector search work at <b>Exactera</b>.
    </p>
    <GitHubContributionGraph />
  </header>

  {
    recentPosts.length > 0 && (
      <>
        <div class="qm-list-head">
          <h2>Recent writing</h2>
          <a href="/blog" class="qm-more">all essays →</a>
        </div>
        <div>
          {recentPosts.map((w) => (
            <a href={`/blog/${w.id}`} class="qm-post">
              <span class="qm-post-date">{formatDate(w.data.pubDate)}</span>
              <div>
                <h3 class="qm-post-title">{w.data.title}</h3>
                <p class="qm-post-summary">{w.data.excerpt ?? w.data.description}</p>
              </div>
              <span class="qm-post-read">{w.readTime}</span>
            </a>
          ))}
        </div>
      </>
    )
  }

  <h2 class="qm-block-h2">Selected work</h2>
  <div>
    {
      projects.map((p, i) => (
        <a href={`/projects/${p.id}`} class="qm-proj">
          <span class="qm-proj-num">№ {String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="qm-proj-title">{p.data.title}</h3>
            <p class="qm-proj-brief">{p.data.description}</p>
            <div class="qm-proj-stack">{p.data.stack.join(' · ')}</div>
          </div>
          <div class="qm-proj-meta">
            <span><b>{p.data.year}</b></span>
            <span>{p.data.role ?? p.data.category}</span>
            <span>{p.data.status}</span>
          </div>
        </a>
      ))
    }
  </div>

  <section id="contact" class="qm-contact-section" aria-labelledby="contact-title">
    <h2 id="contact-title" class="qm-block-h2">Contact</h2>
    <div class="qm-contact">
      <h3>Get in <em>touch.</em></h3>
      <div class="qm-links">
        <a href="mailto:carlos.cruzta@gmail.com"><span>email</span>carlos.cruzta@gmail.com</a>
        <a href="https://github.com/heyimcarlos"><span>github</span>github.com/heyimcarlos</a>
        <a href="https://www.linkedin.com/in/carlos-dev"><span>linkedin</span>/in/carlos-dev</a>
        <a href="/resume.pdf"><span>résumé</span>resume.pdf</a>
      </div>
    </div>
  </section>
</Layout>
