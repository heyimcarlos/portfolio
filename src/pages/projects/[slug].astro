---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted = [...projects].sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    if (a.data.year !== b.data.year) return a.data.year < b.data.year ? 1 : -1;
    return (a.data.order ?? 0) - (b.data.order ?? 0);
  });
  return sorted.map((project, i) => ({
    params: { slug: project.id },
    props: { project, sorted, index: i },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  sorted: CollectionEntry<'projects'>[];
  index: number;
}

const { project, sorted, index } = Astro.props;
const { Content } = await render(project);
const { data } = project;
const n = String(index + 1).padStart(2, '0');

const total = sorted.length;
const prev = total > 1 ? sorted[(index - 1 + total) % total] : null;
const next = total > 1 ? sorted[(index + 1) % total] : null;
---

<Layout title={`${data.title} — Carlos`} description={data.description} active="work">
  <a href="/projects" class="qm-back">← back to work</a>

  <header class="qm-page-head">
    <span class="qm-page-tag">№ {n} · {data.year} · {data.category}</span>
    <h1 class="qm-h1">{data.title}.</h1>
    <p class="qm-lead">{data.description}</p>
  </header>

  <div class="qm-pd-grid">
    <article class="qm-pd-prose">
      <Content />
    </article>
    <aside class="qm-pd-side">
      <dl>
        <dt>Year</dt><dd>{data.year}</dd>
        {data.role && (<><dt>Role</dt><dd>{data.role}</dd></>)}
        <dt>Status</dt><dd>{data.status}</dd>
        <dt>Category</dt><dd>{data.category}</dd>
      </dl>

      <h5>Stack</h5>
      <div class="qm-pd-stack">{data.stack.join(', ')}</div>

      {
        (data.url || data.repo) && (
          <>
            <h5>Links</h5>
            <div class="qm-pd-links">
              {data.url && <a href={data.url}>Live ↗</a>}
              {data.repo && <a href={data.repo}>Source ↗</a>}
            </div>
          </>
        )
      }
    </aside>
  </div>

  {
    (prev || next) && (
      <nav class="qm-navp">
        {prev ? (
          <a class="qm-navp-cell" href={`/projects/${prev.id}`}>
            <span class="qm-navp-k">← Previous</span>
            <span class="qm-navp-v">{prev.data.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="qm-navp-cell right" href={`/projects/${next.id}`}>
            <span class="qm-navp-k">Next →</span>
            <span class="qm-navp-v">{next.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    )
  }
</Layout>

<style>
  .qm-pd-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 64px;
    margin-top: 48px;
  }

  .qm-pd-prose :global(p) {
    font-size: 16px;
    line-height: 1.7;
    color: var(--fg-2);
    margin: 0 0 18px;
    max-width: 60ch;
  }

  .qm-pd-prose :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }

  .qm-pd-prose :global(h2) {
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 36px 0 16px;
    font-weight: 500;
  }

  .qm-pd-prose :global(h3) {
    font-size: 18px;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 28px 0 10px;
  }

  .qm-pd-prose :global(ul),
  .qm-pd-prose :global(ol) {
    padding: 0;
    margin: 0 0 18px;
    list-style: none;
  }

  .qm-pd-prose :global(li) {
    padding: 10px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 15px;
    color: var(--fg-2);
    display: flex;
    gap: 16px;
    align-items: baseline;
  }

  .qm-pd-prose :global(li:last-child) {
    border-bottom: none;
  }

  .qm-pd-prose :global(li::before) {
    content: '→';
    color: var(--accent);
    flex-shrink: 0;
  }

  .qm-pd-prose :global(a) {
    color: var(--fg);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .qm-pd-prose :global(a:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .qm-pd-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--fg);
  }

  .qm-pd-prose :global(pre) {
    background: rgba(244, 243, 238, 0.04);
    border: 1px solid var(--rule);
    padding: 16px 18px;
    font-size: 13px;
    line-height: 1.55;
    overflow-x: auto;
    margin: 0 0 22px;
  }

  .qm-pd-prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .qm-pd-prose :global(blockquote) {
    margin: 24px 0;
    padding: 0 0 0 20px;
    border-left: 2px solid var(--accent);
    color: var(--fg-2);
    font-style: italic;
  }

  .qm-pd-prose :global(img) {
    display: block;
    width: 100%;
    border: 1px solid var(--rule);
    margin: 16px 0 22px;
  }

  .qm-pd-side dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 16px;
    font-size: 13px;
    margin: 0;
  }

  .qm-pd-side dt {
    color: var(--fg-3);
  }

  .qm-pd-side dd {
    margin: 0;
    color: var(--fg);
  }

  .qm-pd-side h5 {
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 36px 0 14px;
    font-weight: 500;
  }

  .qm-pd-stack {
    font-size: 13px;
    color: var(--fg-2);
    line-height: 1.8;
  }

  .qm-pd-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qm-pd-links a {
    color: var(--fg);
    font-size: 13px;
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    align-self: flex-start;
    padding-bottom: 1px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .qm-pd-links a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .qm-navp {
    margin-top: 96px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .qm-navp-cell {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .qm-navp-cell.right {
    align-items: flex-end;
    text-align: right;
  }

  .qm-navp-k {
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .qm-navp-v {
    font-size: 16px;
    color: var(--fg);
    font-weight: 500;
    transition: color 0.2s;
  }

  .qm-navp-cell:hover .qm-navp-v {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .qm-pd-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .qm-navp {
      grid-template-columns: 1fr;
    }
    .qm-navp-cell.right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
